{
  "name": "tk2k-effect-conductor",
  "version": "2.0.1",
  "private": true,
  "author": "lpre_ys",
  "license": "GPL",
  "description": "RPG maker 2000 battle anime maker",
  "dependencies": {
    "@emotion/react": "^11.10.4",
    "@fortawesome/fontawesome-svg-core": "^6.2.0",
    "@fortawesome/free-regular-svg-icons": "^6.2.0",
    "@fortawesome/free-solid-svg-icons": "^6.2.0",
    "@fortawesome/react-fontawesome": "^0.2.0",
    "@reduxjs/toolkit": "^1.9.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^13.5.0",
    "chroma-js": "^2.4.2",
    "d3-ease": "^3.0.1",
    "deepmerge": "^4.2.2",
    "electron-store": "^8.1.0",
    "i18next": "^26.0.6",
    "i18next-fs-backend": "^2.6.4",
    "iconv-lite": "^0.6.3",
    "konva": "^8.3.13",
    "normalize.css": "^8.0.1",
    "react": "^18.2.0",
    "react-color": "^2.19.3",
    "react-dom": "^18.2.0",
    "react-dropzone": "^14.2.2",
    "react-hook-form": "^7.37.0",
    "react-i18next": "^17.0.4",
    "react-konva": "^18.2.2",
    "react-redux": "^8.0.5",
    "tk2k-clipdata": "github:lpre-ys/tk2k-clipdata",
    "use-image": "^1.1.0"
  },
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "clean": "rimraf build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "electron": "electron .",
    "electron-clean": "rimraf dist",
    "electron-build": "electron-builder -w",
    "release": "run-s clean electron-clean build electron-build"
  },
  "devDependencies": {
    "@testing-library/react": "^14.3.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "electron": "^41.0.0",
    "electron-builder": "^26.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.0.2",
    "npm-run-all": "^4.1.5",
    "rimraf": "^3.0.2",
    "vite": "^8.0.9",
    "vitest": "^4.1.4"
  },
  "main": "electron/electron.js",
  "build": {
    "appId": "com.lpre-ys.effedct-conductor",
    "productName": "EffectConductor",
    "files": [
      "electron/**/*",
      "build/**/*",
      "package.json"
    ],
    "extraFiles": [
      "readme.txt",
      "LICENSE"
    ],
    "asarUnpack": [
      "node_modules/tk2k-clipdata/"
    ],
    "directories": {
      "buildResources": "asset"
    },
    "win": {
      "icon": "asset/icon.png",
      "target": "nsis"
    },
    "nsis": {
      "artifactName": "${productName}_setup_${version}.${ext}",
      "include": "asset/installer.nsh",
      "oneClick": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": false
    }
  }
}
